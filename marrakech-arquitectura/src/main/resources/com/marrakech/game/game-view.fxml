<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.marrakech.game.presentation.controllers.GameController"
           stylesheets="@styles.css" styleClass="root-pane">
  <children>

    <!-- ══ PANTALLA INICIO ══ -->
    <VBox fx:id="startScreen" alignment="CENTER" spacing="30.0" visible="true">
      <children>
        <ImageView fitHeight="120" fitWidth="120" preserveRatio="true">
          <image><Image url="/images/assam.png"/></image>
        </ImageView>
        <Label text="MARRAKECH"
               style="-fx-font-size:42px;-fx-font-weight:bold;-fx-text-fill:#D4A017;
                      -fx-effect:dropshadow(gaussian,#7A4500,14,0.5,4,4);"/>
        <Label text="¿Cuántos jugadores?" style="-fx-font-size:20px;-fx-text-fill:#E8D4A0;"/>
        <HBox alignment="CENTER" spacing="20.0">
          <Button text="2 Jugadores" styleClass="btn" onAction="#startWith2" mnemonicParsing="false"/>
          <Button text="3 Jugadores" styleClass="btn" onAction="#startWith3" mnemonicParsing="false"/>
          <Button text="4 Jugadores" styleClass="btn" onAction="#startWith4" mnemonicParsing="false"/>
        </HBox>
      </children>
    </VBox>

    <!-- ══ PANTALLA DE JUEGO ══ -->
    <HBox fx:id="gameScreen" alignment="CENTER" spacing="10.0" visible="false">
      <children>

        <!-- Panel J1 y J2 (izquierda) -->
        <VBox alignment="TOP_CENTER" spacing="10.0" prefWidth="150.0">
          <children>
            <VBox fx:id="panelJ1" alignment="CENTER" spacing="6.0" styleClass="panel">
              <children>
                <Label text="J1" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#e74c3c;"/>
                <ImageView fitHeight="38" fitWidth="38" preserveRatio="true">
                  <image><Image url="/images/alfombra tablero roja.png"/></image>
                </ImageView>
                <Label text="Alfombras" styleClass="status-label"/>
                <Label fx:id="rugsJ1" text="15" style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
                <Label text="Dirhams" styleClass="status-label"/>
                <Label fx:id="moneyJ1" text="30 Dh" style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
              </children>
              <padding><Insets bottom="10.0" left="8.0" right="8.0" top="10.0"/></padding>
            </VBox>
            <VBox fx:id="panelJ2" alignment="CENTER" spacing="6.0" styleClass="panel">
              <children>
                <Label text="J2" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#3498db;"/>
                <ImageView fitHeight="38" fitWidth="38" preserveRatio="true">
                  <image><Image url="/images/alfombra tablero azul.png"/></image>
                </ImageView>
                <Label text="Alfombras" styleClass="status-label"/>
                <Label fx:id="rugsJ2" text="15" style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
                <Label text="Dirhams" styleClass="status-label"/>
                <Label fx:id="moneyJ2" text="30 Dh" style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
              </children>
              <padding><Insets bottom="10.0" left="8.0" right="8.0" top="10.0"/></padding>
            </VBox>
          </children>
          <padding><Insets bottom="8.0" left="6.0" right="6.0" top="8.0"/></padding>
        </VBox>

        <!-- ══ ZONA CENTRAL ══ -->
        <VBox alignment="CENTER" spacing="8.0">
          <children>

            <VBox alignment="CENTER" spacing="3.0" styleClass="panel">
              <children>
                <Label fx:id="turnLabel" styleClass="title-label" text="TURNO: J1"/>
                <Label fx:id="statusLabel" styleClass="status-label"
                       text="Rota a Assam y lanza el dado."
                       wrapText="true" maxWidth="460.0"/>
              </children>
              <padding><Insets bottom="7.0" left="12.0" right="12.0" top="7.0"/></padding>
            </VBox>

            <!-- TABLERO con marco árabe -->
            <VBox styleClass="board-frame" alignment="CENTER">
              <children>
                <Label text="✦  ✦  ✦  ✦  ✦  ✦  ✦"
                       style="-fx-text-fill:#D4A017;-fx-font-size:11px;-fx-padding:0 0 3 0;"/>
                <Pane minWidth="640.0" minHeight="601.0"
                      prefWidth="640.0" prefHeight="601.0"
                      maxWidth="640.0" maxHeight="601.0">
                  <children>
                    <ImageView layoutX="0.0" layoutY="0.0"
                               fitWidth="640.0" fitHeight="601.0"
                               preserveRatio="false" pickOnBounds="false">
                      <image><Image url="/images/tablero.png"/></image>
                    </ImageView>
                    <GridPane fx:id="boardGrid"
                              layoutX="73.0" layoutY="66.0"
                              hgap="0" vgap="0"
                              minWidth="427.0"  minHeight="427.0"
                              prefWidth="427.0" prefHeight="427.0"
                              maxWidth="427.0"  maxHeight="427.0"
                              styleClass="grid-overlay"/>
                  </children>
                </Pane>
                <Label text="✦  ✦  ✦  ✦  ✦  ✦  ✦"
                       style="-fx-text-fill:#D4A017;-fx-font-size:11px;-fx-padding:3 0 0 0;"/>
              </children>
              <padding><Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/></padding>
            </VBox>

            <HBox alignment="CENTER" spacing="10.0" styleClass="panel">
              <children>
                <Button mnemonicParsing="false" onAction="#rotateLeft"
                        styleClass="btn-small" text="↶  Girar Izq"/>
                <Button fx:id="rollDiceBtn" mnemonicParsing="false"
                        onAction="#onRollDiceClick" styleClass="btn" text="🎲  Lanzar Dado"/>
                <Button mnemonicParsing="false" onAction="#rotateRight"
                        styleClass="btn-small" text="Girar Der  ↷"/>
              </children>
              <padding><Insets bottom="7.0" left="12.0" right="12.0" top="7.0"/></padding>
            </HBox>
          </children>
        </VBox>

        <!-- ══ CHAT LATERAL ══ -->
        <VBox fx:id="chatPanel" styleClass="chat-panel" prefWidth="220.0"
              minWidth="220.0" maxWidth="220.0" spacing="6.0">
          <children>
            <Label text="💬  CHAT DE PARTIDA" styleClass="chat-title"
                   maxWidth="9999.0"
                   style="-fx-padding:8 0 4 0;"/>
            <ScrollPane fx:id="chatScroll" styleClass="chat-area"
                        fitToWidth="true" hbarPolicy="NEVER"
                        VBox.vgrow="ALWAYS" prefHeight="9999.0">
              <content>
                <VBox fx:id="chatBox" spacing="6.0">
                  <padding><Insets bottom="6.0" left="6.0" right="6.0" top="6.0"/></padding>
                </VBox>
              </content>
            </ScrollPane>
            <HBox spacing="5.0" alignment="CENTER_LEFT">
              <children>
                <TextField fx:id="chatInput" styleClass="chat-input"
                           promptText="Escribe..." HBox.hgrow="ALWAYS"/>
                <Button fx:id="chatSendBtn" text="➤" styleClass="chat-send-btn"
                        onAction="#onSendChat" mnemonicParsing="false"/>
              </children>
              <padding><Insets bottom="2.0" left="4.0" right="4.0" top="0.0"/></padding>
            </HBox>
          </children>
          <padding><Insets bottom="8.0" left="8.0" right="8.0" top="4.0"/></padding>
        </VBox>

        <!-- Panel J3 y J4 (derecha) -->
        <VBox alignment="TOP_CENTER" spacing="10.0" prefWidth="150.0">
          <children>
            <VBox fx:id="panelJ3" alignment="CENTER" spacing="6.0" styleClass="panel"
                  visible="false" managed="false">
              <children>
                <Label text="J3" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#2ecc71;"/>
                <ImageView fitHeight="38" fitWidth="38" preserveRatio="true">
                  <image><Image url="/images/alfombra tablero morada.png"/></image>
                </ImageView>
                <Label text="Alfombras" styleClass="status-label"/>
                <Label fx:id="rugsJ3" text="15" style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
                <Label text="Dirhams" styleClass="status-label"/>
                <Label fx:id="moneyJ3" text="30 Dh" style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
              </children>
              <padding><Insets bottom="10.0" left="8.0" right="8.0" top="10.0"/></padding>
            </VBox>
            <VBox fx:id="panelJ4" alignment="CENTER" spacing="6.0" styleClass="panel"
                  visible="false" managed="false">
              <children>
                <Label text="J4" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#f39c12;"/>
                <ImageView fitHeight="38" fitWidth="38" preserveRatio="true">
                  <image><Image url="/images/alfombra tablero amarillo.png"/></image>
                </ImageView>
                <Label text="Alfombras" styleClass="status-label"/>
                <Label fx:id="rugsJ4" text="15" style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
                <Label text="Dirhams" styleClass="status-label"/>
                <Label fx:id="moneyJ4" text="30 Dh" style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#F0E0B0;"/>
              </children>
              <padding><Insets bottom="10.0" left="8.0" right="8.0" top="10.0"/></padding>
            </VBox>
          </children>
          <padding><Insets bottom="8.0" left="6.0" right="6.0" top="8.0"/></padding>
        </VBox>

      </children>
      <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>
    </HBox>

    <!-- ══ FIN DE JUEGO — combina ambas ramas ══ -->
    <VBox fx:id="endScreen" alignment="CENTER" spacing="25.0" visible="false"
          style="-fx-background-color: rgba(0,0,0,0.92);">
      <children>
        <Label fx:id="resultadoLabel" text=""
               style="-fx-font-size:56px;-fx-font-weight:bold;-fx-text-fill:#d4af37;"/>
        <Label fx:id="winnerLabel" text=""
               style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:white;"/>
        <Label fx:id="finalScores" text=""
               style="-fx-font-size:16px;-fx-text-fill:#E8D4A0;"
               wrapText="true" maxWidth="500.0"/>
        <HBox alignment="CENTER" spacing="20.0">
          <Button fx:id="btnVolverSala" text="Volver a la sala" styleClass="btn"
                  onAction="#volverSala" mnemonicParsing="false"/>
          <Button fx:id="btnVolverMenu" text="Menú principal" styleClass="btn"
                  onAction="#volverMenu" mnemonicParsing="false"/>
        </HBox>
      </children>
    </VBox>

  </children>
</StackPane>
